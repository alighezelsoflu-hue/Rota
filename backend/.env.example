# Local backend settings
# For local SQLite testing, you can leave DATABASE_URL unset.
# For Neon/Supabase/Postgres deployment, use your hosted Postgres connection string.
DATABASE_URL=sqlite:///./rota.db
JWT_SECRET=change-this-to-a-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=uploads
